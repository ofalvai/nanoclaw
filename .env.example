# Added by skill
TELEGRAM_BOT_TOKEN=
TELEGRAM_ONLY=

# AgentLogs session observability (https://agentlogs.ai)
# Set AGENTLOGS_AUTH_TOKEN to enable. Get your token from the AgentLogs UI.
# AGENTLOGS_SERVER_URL defaults to http://localhost:3000 (self-hosted).
AGENTLOGS_AUTH_TOKEN=
AGENTLOGS_SERVER_URL=http://localhost:3000

# Webhook channel — accepts external events via HTTP and routes them to the agent.
# Set WEBHOOK_PORT to enable. Binds to 127.0.0.1 by default (loopback only).
# WEBHOOK_TOKEN enforces bearer token auth on all requests (recommended).
# WEBHOOK_ALLOWED_GROUPS: comma-separated group folder names that may be targeted (e.g. main,family).
# Requests targeting unlisted groups are rejected with 403. Required for the channel to activate.
# Generate a token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_PORT=3200
WEBHOOK_HOST=127.0.0.1
WEBHOOK_RATE_LIMIT_PER_MINUTE=60
WEBHOOK_TOKEN=
WEBHOOK_ALLOWED_GROUPS=
